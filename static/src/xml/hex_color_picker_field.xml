<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="web_branding_company.HexColorPickerField" owl="1">
        <div class="o_hex_color_picker_field" t-att-class="invalidClass">
            <input type="color" class="o_hex_color_input" t-att-value="colorValue" t-on-input="onColorInput"/>
            <input type="text" class="o_input o_hex_text_input" maxlength="7" placeholder="#RRGGBB" t-att-value="displayText" t-on-input="onTextInput" t-on-blur="onTextBlur"/>
            <span class="o_hex_preview_chip" t-att-style="`background-color: ${colorValue}`" title="Kleurpreview"/>
        </div>
    </t>
</templates>

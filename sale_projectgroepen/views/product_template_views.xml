<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_projectgroepen_inherit" model="ir.ui.view">
        <field name="name">product.template.form.projectgroepen.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet//group/group[1]" position="inside">
                <field name="project_group_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                <field name="excluded_pricelist_ids" widget="many2many_tags"/>
            </xpath>
        </field>
    </record>
</odoo>

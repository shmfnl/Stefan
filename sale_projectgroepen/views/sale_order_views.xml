<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_projectgroepen_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.projectgroepen.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//field[@name='product_template_id']" position="before">
                <field name="x_toegestane_product_template_ids" column_invisible="1" invisible="1"/>
                <field name="x_toegestane_product_ids" column_invisible="1" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='order_line']//field[@name='product_template_id']" position="attributes">
                <attribute name="domain">[('id', 'in', x_toegestane_product_template_ids)]</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//field[@name='product_id']" position="attributes">
                <attribute name="domain">[('id', 'in', x_toegestane_product_ids)]</attribute>
            </xpath>
        </field>
    </record>
</odoo>
